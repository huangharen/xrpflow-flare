# Required only when deploying the escrow contract to Coston2.
# Never commit a funded production wallet key.
COSTON2_PRIVATE_KEY=0xYOUR_DEDICATED_TESTNET_PRIVATE_KEY

# Add this after deployment so the web app enables live transaction mode.
NEXT_PUBLIC_TREASURY_ADDRESS=0xDEPLOYED_XRPFLOW_ESCROW_ADDRESS
NEXT_PUBLIC_TREASURY_DEPLOY_BLOCK=DEPLOYMENT_BLOCK_NUMBER
